[{"id":"r1","title":"Сырники без драмы","category":["завтрак","сладкое","быстро"],"time":"25 мин","heat":"5 из 9","portions":"2 порц.","emoji":"🥞","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%A5%9E%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["творог 5–9% — 360 г","яйцо — 1 шт.","мука — 45 г + 20 г на обвалку","сахар — 25 г","соль — щепотка","масло — 1 ст. л."],"steps":["Смешай творог, яйцо, сахар и соль. Комочки — это не провал, это характер.","Добавь муку и слепи сырники влажными руками.","Жарь на огне 5/9 по 3–4 минуты с каждой стороны.","Подавай со сметаной или ягодами. Ты молодец, сырники не осуждают."]},{"id":"r2","title":"Омлет с сыром и беконом","category":["завтрак","яйца","быстро"],"time":"15 мин","heat":"4 из 9","portions":"1–2 порц.","emoji":"🍳","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%8D%B3%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["яйца — 3 шт.","молоко — 40 мл","сыр — 50 г","бекон — 60 г","соль, перец — по вкусу"],"steps":["Бекон обжарь 2–3 минуты на огне 5/9.","Яйца взбей с молоком, солью и перцем.","Вылей смесь к бекону, убавь до 4/9 и накрой крышкой на 5–6 минут.","Посыпь сыром и дай расплавиться. Сыр — это одеяло для омлета."]},{"id":"r3","title":"Пюре с котлетками","category":["ужин","картошка","мясо","уютное"],"time":"45 мин","heat":"6 из 9","portions":"3 порц.","emoji":"🥔","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%A5%94%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["картофель — 700 г","молоко — 120 мл","сливочное масло — 40 г","фарш — 450 г","лук — 1 шт.","яйцо — 1 шт.","сухари — 3 ст. л."],"steps":["Картошку отвари 20 минут до мягкости.","Фарш смешай с луком, яйцом, сухарями, солью и перцем.","Сформируй котлеты и жарь на огне 6/9 по 5–6 минут с каждой стороны.","Картошку разомни с молоком и маслом. Это уже не ужин, это терапия."]},{"id":"r4","title":"Гречка с курицей в сливках","category":["ужин","курица","крупы","уютное"],"time":"35 мин","heat":"5 из 9","portions":"2–3 порц.","emoji":"🍗","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%8D%97%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["гречка — 180 г","куриное филе — 350 г","сливки 10–20% — 150 мл","лук — 1 шт.","масло — 1 ст. л.","соль, паприка — по вкусу"],"steps":["Гречку промой и вари 15–18 минут.","Курицу нарежь кубиками, обжарь с луком на огне 6/9 около 7 минут.","Добавь сливки, соль, паприку, убавь до 4/9 и потуши 8 минут.","Смешай с гречкой. Очень домашне, почти как плед, только съедобный."]},{"id":"r5","title":"Куриный суп с лапшой","category":["суп","курица","лёгкое"],"time":"40 мин","heat":"6 из 9","portions":"4 порц.","emoji":"🥣","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%A5%A3%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["курица — 400 г","вода — 1.5 л","картофель — 2 шт.","морковь — 1 шт.","лук — 1 шт.","лапша — 70 г","зелень — по вкусу"],"steps":["Курицу залей водой и вари 20 минут, снимая пену как взрослый ответственный человек.","Добавь картофель, морковь и лук, вари 12 минут.","Добавь лапшу, вари ещё 5–7 минут.","Посоли, добавь зелень. Суп готов обнимать изнутри."]},{"id":"r6","title":"Сливочная паста с курицей","category":["паста","курица","сырное","ужин"],"time":"30 мин","heat":"6 из 9","portions":"2 порц.","emoji":"🍝","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%8D%9D%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["паста — 180 г","куриное филе — 300 г","сливки — 180 мл","сыр — 60 г","чеснок — 1 зубчик","масло — 1 ст. л."],"steps":["Пасту отвари до аль денте, не до состояния грустной каши.","Курицу обжарь на огне 6/9 7–8 минут.","Добавь чеснок, сливки и сыр, убавь до 4/9, прогрей 3–4 минуты.","Смешай с пастой. Ужин выглядит так, будто ты старалась весь день."]},{"id":"r7","title":"Лаваш с сыром и курицей","category":["лаваш","курица","сырное","быстро"],"time":"18 мин","heat":"5 из 9","portions":"2 порц.","emoji":"🌯","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%8C%AF%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["лаваш — 2 листа","курица готовая/обжаренная — 250 г","сыр — 100 г","сметана — 2 ст. л.","зелень — по вкусу"],"steps":["Смешай курицу, сыр, сметану и зелень.","Заверни в лаваш конвертиком. Без перфекционизма, это не оригами.","Поджарь на сухой сковороде на огне 5/9 по 2–3 минуты с каждой стороны.","Ешь горячим, пока сыр тянется как сериал на 8 сезонов."]},{"id":"r8","title":"Пельмени в сливочном соусе","category":["быстро","полуфабрикат","уютное","сырное"],"time":"20 мин","heat":"5 из 9","portions":"2 порц.","emoji":"🥟","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%A5%9F%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["пельмени — 400 г","сливки — 150 мл","сыр — 50 г","чеснок — 1 зубчик","масло — 10 г","перец — по вкусу"],"steps":["Пельмени отвари 5–7 минут после всплытия.","На сковороде растопи масло, добавь чеснок на 30 секунд.","Влей сливки, добавь сыр, прогрей на огне 4/9.","Закинь пельмени в соус. Иногда пельмени — это тоже забота о себе."]},{"id":"r9","title":"Рис с яйцом и овощами","category":["рис","яйца","быстро","лёгкое"],"time":"22 мин","heat":"6 из 9","portions":"2 порц.","emoji":"🍚","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%8D%9A%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["рис варёный — 300 г","яйца — 2 шт.","овощная смесь — 200 г","соевый соус — 2 ст. л.","масло — 1 ст. л."],"steps":["Овощи обжарь на огне 6/9 4–5 минут.","Сдвинь овощи, вбей яйца и быстро перемешай.","Добавь рис и соевый соус, жарь ещё 3–4 минуты.","Получилось почти как доставка, только без ожидания курьера."]},{"id":"r10","title":"Картошка с грибами","category":["картошка","ужин","без мяса","уютное"],"time":"35 мин","heat":"6 из 9","portions":"2–3 порц.","emoji":"🍄","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%8D%84%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["картофель — 600 г","грибы — 250 г","лук — 1 шт.","масло — 2 ст. л.","соль, перец — по вкусу"],"steps":["Картошку нарежь тонкими ломтиками, промой и обсуши.","Жарь на огне 6/9 12–15 минут, периодически мешая.","Добавь грибы и лук, жарь ещё 10 минут.","Посоли в конце, чтобы картошка не обиделась и не развалилась."]},{"id":"r11","title":"Творожный десерт с ягодами","category":["сладкое","без готовки","лёгкое"],"time":"7 мин","heat":"без огня","portions":"1–2 порц.","emoji":"🍓","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%8D%93%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["творог мягкий — 200 г","йогурт — 100 г","ягоды — 120 г","мёд — 1 ст. л.","печенье — 2 шт."],"steps":["Смешай творог, йогурт и мёд.","Печенье раскроши. Да, руками, мы тут живые люди.","Собери слоями: крем, ягоды, печенье.","Ешь сразу или охлади 5 минут, если терпение ещё живо."]},{"id":"r12","title":"Сырный суп без понтов","category":["суп","сырное","быстро","уютное"],"time":"30 мин","heat":"5 из 9","portions":"3 порц.","emoji":"🧀","image":"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201200'%3E%3Crect%20width='1200'%20height='1200'%20fill='%23201820'/%3E%3Ccircle%20cx='250'%20cy='220'%20r='170'%20fill='%23ff7a59'%20opacity='.22'/%3E%3Ctext%20x='600'%20y='635'%20font-size='300'%20text-anchor='middle'%3E%F0%9F%A7%80%3C/text%3E%3Ctext%20x='600'%20y='870'%20font-family='Arial'%20font-size='54'%20font-weight='900'%20fill='white'%20text-anchor='middle'%3ECozy%20Foodie%3C/text%3E%3C/svg%3E","ingredients":["картофель — 3 шт.","морковь — 1 шт.","плавленый сыр — 160 г","вода — 1.2 л","курица/ветчина — 150 г по желанию","зелень — по вкусу"],"steps":["Картошку и морковь вари 15 минут.","Добавь курицу или ветчину, если хочется посытнее.","Вмешай сыр на огне 4/9 до растворения.","Попробуй на соль. Сырный суп — это когда жизнь стала чуть мягче."]}]